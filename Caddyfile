:80 {
    handle /api/* {
        reverse_proxy localhost:3001
    }

    handle {
        root * /srv
        file_server

        try_files {path} {path}/index.html {path}.html /index.html

        @astro path /_astro/*
        header @astro Cache-Control "public, max-age=31536000, immutable"

        @dotfiles path /.*
        respond @dotfiles 404

        encode gzip
    }
}
