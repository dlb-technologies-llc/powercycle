{
	"name": "powercycle",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter @powercycle/frontend build",
		"dev": "bun run --filter @powercycle/frontend dev & bun run --filter @powercycle/backend dev & wait",
		"dev:server": "bun run --filter @powercycle/backend start",
		"dev:frontend": "bun run --filter @powercycle/frontend dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "bun --filter './packages/*' typecheck",
		"test:unit": "vitest run",
		"test:e2e": "bun run --cwd packages/frontend playwright test",
		"test:e2e:docker": "bun run --cwd packages/frontend playwright test --config playwright.docker.config.ts",
		"test": "bun run test:unit",
		"docker:dev": "docker compose -f docker-compose.dev.yml up -d",
		"docker:down": "docker compose -f docker-compose.dev.yml down",
		"docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
		"db:generate": "bun --filter './packages/backend' db:generate",
		"db:migrate": "bun --filter './packages/backend' db:migrate"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"@effect/vitest": "4.0.0-beta.40",
		"tw-animate-css": "^1.4.0",
		"vitest": "^3.2.4"
	}
}
