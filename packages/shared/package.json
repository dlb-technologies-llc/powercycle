{
	"name": "@powercycle/shared",
	"version": "0.0.1",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./api/*": "./src/api/*.ts",
		"./schema/*": "./src/schema/*.ts",
		"./engine/*": "./src/engine/*.ts",
		"./errors/*": "./src/errors/*.ts"
	},
	"scripts": {
		"test": "vitest run --config ../../vitest.config.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"effect": "4.0.0-beta.40"
	},
	"devDependencies": {
		"@effect/vitest": "4.0.0-beta.40",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
