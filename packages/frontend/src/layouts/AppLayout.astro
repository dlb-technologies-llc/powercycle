---
import "../styles/global.css";
interface Props {
	title?: string;
}
const { title = "PowerCycle" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#09090b" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-zinc-950 text-zinc-100">
		<header class="relative px-6 py-4">
			<div class="flex items-center justify-between max-w-2xl mx-auto">
				<a
					href="/"
					class="font-heading text-xl font-bold tracking-wider uppercase text-zinc-100 hover:text-accent-cyan transition-colors"
				>
					POWERCYCLE
				</a>
				<nav class="hidden sm:flex items-center gap-4">
					<a
						href="/"
						class:list={[
							"text-sm transition-colors",
							currentPath === "/"
								? "text-accent-cyan"
								: "text-zinc-400 hover:text-accent-cyan",
						]}
					>
						Dashboard
					</a>
					<a
						href="/history"
						class:list={[
							"text-sm transition-colors",
							currentPath === "/history"
								? "text-accent-cyan"
								: "text-zinc-400 hover:text-accent-cyan",
						]}
					>
						History
					</a>
				</nav>
			</div>
			<div
				class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/40 to-transparent"
			>
			</div>
		</header>
		<main class="max-w-2xl mx-auto px-6 py-8 pb-20">
			<slot />
		</main>
		<nav
			class="fixed bottom-0 left-0 right-0 sm:hidden bg-zinc-950/90 backdrop-blur-lg border-t border-zinc-800/50 z-50"
		>
			<div class="flex items-center justify-around max-w-2xl mx-auto py-2">
				<a
					href="/"
					class:list={[
						"flex flex-col items-center gap-1 px-4 py-2 transition-colors",
						currentPath === "/"
							? "text-accent-cyan"
							: "text-zinc-500 hover:text-zinc-300",
					]}
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
						></path>
						<polyline points="9 22 9 12 15 12 15 22"></polyline>
					</svg>
					<span class="text-xs font-medium">Dashboard</span>
				</a>
				<a
					href="/history"
					class:list={[
						"flex flex-col items-center gap-1 px-4 py-2 transition-colors",
						currentPath === "/history"
							? "text-accent-cyan"
							: "text-zinc-500 hover:text-zinc-300",
					]}
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<circle cx="12" cy="12" r="10"></circle>
						<polyline points="12 6 12 12 16 14"></polyline>
					</svg>
					<span class="text-xs font-medium">History</span>
				</a>
			</div>
		</nav>
	</body>
</html>
